# =============================================
# COPY THIS FILE TO .env AND FILL IN YOUR KEYS
# NEVER COMMIT .env TO GITHUB
# =============================================

# AI Provider (gemini or claude)
AI_PROVIDER=gemini

# Google Gemini API Key
# Get free key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API Key (optional - pay per use)
# Get key at: https://console.anthropic.com
CLAUDE_API_KEY=your_claude_api_key_here

# AviationStack API Key (100 req/month free)
# Get free key at: https://aviationstack.com/signup/free
AVIATIONSTACK_API_KEY=your_aviationstack_key_here

# CORS - comma separated list of allowed frontend URLs
# Local: http://localhost:4200
# Production: https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:4200
